@page "/"
@inject SessionService SessionService

<PageTitle>Trang chủ - CoffeeShop</PageTitle>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12 text-center">
            <h1 class="display-4 text-primary fw-bold mb-4">Chào mừng đến với CoffeeShop</h1>
            
            <AuthorizeView>
                <Authorized>
                    <p class="lead">Xin chào, @context.User.Identity?.Name!</p>
                    @if (context.User.IsInRole("Manager") || context.User.IsInRole("Employee"))
                    {
                        <div class="mt-5">
                            <h4 class="mb-4">Truy cập nhanh</h4>
                            <div class="d-flex justify-content-center gap-3 flex-wrap">
                                <a href="/employee/pos" class="btn btn-outline-primary btn-lg p-4">
                                    <i class="bi bi-cart-fill display-6 d-block mb-2"></i>
                                    Mở POS
                                </a>
                                <a href="/employee/tablemap" class="btn btn-outline-success btn-lg p-4">
                                    <i class="bi bi-grid-3x3-gap-fill display-6 d-block mb-2"></i>
                                    Sơ đồ bàn
                                </a>
                                <a href="/employee/orders" class="btn btn-outline-info btn-lg p-4">
                                    <i class="bi bi-receipt display-6 d-block mb-2"></i>
                                    Hóa đơn
                                </a>
                            </div>
                        </div>
                    }
                </Authorized>
                <NotAuthorized>
                    <p class="lead">Vui lòng đăng nhập để sử dụng các tính năng của hệ thống.</p>
                    <a href="/login" class="btn btn-primary btn-lg mt-3">Đăng nhập ngay</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </div>
</div>
