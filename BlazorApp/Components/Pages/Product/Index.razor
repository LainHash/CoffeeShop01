@page "/Product/Index"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Manager")]
@inject IProductApiService ProductApiService

<PageTitle>Quản lý Sản phẩm - CoffeeShop</PageTitle>

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 position-relative overlay-bottom">
    <div class="d-flex flex-column align-items-center justify-content-center pt-0 pt-lg-5" style="min-height: 400px">
        <h1 class="display-4 mb-3 mt-0 mt-lg-5 text-white text-uppercase">Quản lý Sản phẩm</h1>
        <div class="d-inline-flex mb-lg-5">
            <p class="m-0 text-white"><a class="text-white" href="/">Trang Chủ</a></p>
            <p class="m-0 text-white px-2">/</p>
            <p class="m-0 text-white">Quản lý Sản phẩm</p>
        </div>
    </div>
</div>
<!-- Page Header End -->

<AlertMessage @ref="alert" />
<LoadingSpinner IsLoading="isLoading" />

@if (!isLoading && products != null)
{
    <div class="container-fluid pt-5">
        <div class="container">
            <div class="section-title position-relative text-center mx-auto mb-5" style="max-width: 600px;">
                <h1 class="display-4">Quản Lý Sản Phẩm</h1>
                <span class="text-primary font-weight-bold">Danh sách các sản phẩm của quán</span>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
                    <h5 class="mb-0 text-white"><i class="fa fa-list mr-2 text-primary"></i>Danh Sách Sản Phẩm</h5>
                    <a href="/Product/Create" class="btn btn-primary btn-sm rounded-pill"><i class="fa fa-plus mr-1"></i>Thêm Mới</a>
                </div>
                <div class="card-body bg-light">
                    <div class="table-responsive">
                        <table class="table table-hover bg-white mb-0">
                            <thead class="thead-light">
                                <tr>
                                    <th scope="col" class="py-3" style="width: 80px">Hình ảnh</th>
                                    <th scope="col" class="py-3">Tên sản phẩm</th>
                                    <th scope="col" class="py-3">Danh mục</th>
                                    <th scope="col" class="py-3">Giá</th>
                                    <th scope="col" class="py-3">Trạng thái</th>
                                    <th scope="col" class="py-3">Tồn kho</th>
                                    <th scope="col" class="py-3 text-center">Hành Động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (products.Count == 0)
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-5 text-muted">
                                            <i class="fa fa-box-open fa-3x mb-3 text-light"></i>
                                            <p class="mb-0">Không có sản phẩm nào.</p>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var p in products)
                                    {
                                        <tr>
                                            <td class="py-3">
                                                <img src="@(string.IsNullOrEmpty(p.ImageUrl) ? "images/no-image.png" : p.ImageUrl)" 
                                                     class="rounded object-fit-cover" width="50" height="50" />
                                            </td>
                                            <td class="font-weight-bold text-dark py-3">@p.ProductName</td>
                                            <td class="py-3 text-secondary">@p.CategoryName</td>
                                            <td class="py-3">@p.Price.ToString("N0") đ</td>
                                            <td class="py-3">
                                                @if (p.IsAvailable)
                                                {
                                                    <span class="badge badge-success px-3 py-1 font-weight-normal">
                                                        <i class="fa fa-check mr-1"></i> Đang bán
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-danger px-3 py-1 font-weight-normal">
                                                        <i class="fa fa-times mr-1"></i> Ngừng bán
                                                    </span>
                                                }
                                            </td>
                                            <td class="py-3">
                                                @if (p.IsMadeToOrder)
                                                {
                                                    <span class="text-muted fst-italic">Pha chế khi đặt</span>
                                                }
                                                else
                                                {
                                                    @p.UnitsInstock
                                                }
                                            </td>
                                            <td class="text-center py-3">
                                                <div class="btn-group" role="group">
                                                    <a href="/Product/Edit/@p.PublicId" class="btn btn-outline-primary btn-sm rounded-left" title="Sửa">
                                                        <i class="fa fa-edit"></i> Sửa
                                                    </a>
                                                    <a href="/Product/Delete/@p.PublicId" class="btn btn-outline-danger btn-sm rounded-right" title="Xóa">
                                                        <i class="fa fa-trash"></i> Xóa
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ProductModel>? products;
    private bool isLoading = true;
    private AlertMessage alert = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        isLoading = true;
        var result = await ProductApiService.GetAllAsync();
        
        if (result != null && result.Success)
        {
            products = result.List;
        }
        else
        {
            alert.ShowError(result?.Message ?? "Không thể tải danh sách sản phẩm.");
        }
        isLoading = false;
    }
}

