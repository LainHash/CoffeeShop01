@page "/order/details/{Id:guid}"
@attribute [Authorize]
@inject IOrderApiService OrderApiService
@inject NavigationManager NavigationManager

<PageTitle>Chi tiết Đơn hàng - CoffeeShop</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Chi tiết Hóa đơn</h2>
    <a href="javascript:history.back()" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

<AlertMessage @ref="alert" />
<LoadingSpinner IsLoading="isLoading" />

@if (!isLoading && order != null)
{
    <div class="row">
        <!-- Order Info -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Thông tin chung</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Mã HĐ:</span>
                            <span class="fw-bold">#@order.OrderId</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Bàn:</span>
                            <span class="fw-bold">Bàn @order.TableNumber (Tầng @order.FloorNumber)</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between">
                            <span class="text-muted">Nhân viên:</span>
                            <span>@order.EmployeeName</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span class="text-muted">Trạng thái:</span>
                            <span class="badge @order.StatusBadgeClass">@order.StatusLabel</span>
                        </li>
                        @if (!string.IsNullOrEmpty(order.Note))
                        {
                            <li class="list-group-item">
                                <span class="text-muted d-block mb-1">Ghi chú:</span>
                                <span>@order.Note</span>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>

        <!-- Order Items -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Chi tiết món</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th class="text-center">Đơn giá</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in order.OrderDetails)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                                {
                                                    <img src="@item.ImageUrl" class="rounded object-fit-cover" width="40" height="40" />
                                                }
                                                <span class="fw-bold">@item.ProductName</span>
                                            </div>
                                        </td>
                                        <td class="text-center align-middle">@item.UnitPrice.ToString("N0")đ</td>
                                        <td class="text-center align-middle">@item.Quantity</td>
                                        <td class="text-end align-middle fw-bold">@item.LineTotal.ToString("N0")đ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-light p-3">
                    <div class="row justify-content-end">
                        <div class="col-md-6 col-lg-5">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Tạm tính:</span>
                                <span>@order.SubTotal.ToString("N0")đ</span>
                            </div>
                            @if (order.DiscountId != null)
                            {
                                <div class="d-flex justify-content-between mb-2 text-success">
                                    <span>Giảm giá (@order.DiscountCode):</span>
                                    <span>-@((order.SubTotal - order.TotalAmount).ToString("N0"))đ</span>
                                </div>
                            }
                            <div class="d-flex justify-content-between mt-2 pt-2 border-top">
                                <span class="fw-bold fs-5">Tổng tiền:</span>
                                <span class="fw-bold fs-5 text-primary">@order.TotalAmount.ToString("N0")đ</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private OrderModel? order;
    private bool isLoading = true;
    private AlertMessage alert = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrderDetails();
    }

    private async Task LoadOrderDetails()
    {
        isLoading = true;
        var result = await OrderApiService.GetByIdAsync(Id);
        
        if (result != null && result.Success && result.GetOrder() != null)
        {
            order = result.GetOrder();
        }
        else
        {
            alert.ShowError(result?.Message ?? "Không tìm thấy thông tin hóa đơn.");
        }
        isLoading = false;
    }
}
