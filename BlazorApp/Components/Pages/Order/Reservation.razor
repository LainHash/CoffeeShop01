@page "/order/reservation"
@attribute [Authorize(Roles = "Manager,Employee")]
@inject IReservationApiService ReservationApiService
@inject ITableApiService TableApiService
@inject NavigationManager NavigationManager

<PageTitle>Tạo Đặt bàn mới - CoffeeShop</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="bi bi-calendar-plus"></i> Tạo Đặt bàn Mới</h4>
            </div>
            <div class="card-body p-4">
                <AlertMessage @ref="alert" />

                <EditForm Model="input" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Tên khách hàng <span class="text-danger">*</span></label>
                            <InputText @bind-Value="input.FullName" class="form-control" placeholder="Nhập tên khách hàng" />
                        </div>
                        <div class="col-md-6 mt-3 mt-md-0">
                            <label class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                            <InputText @bind-Value="input.Phone" class="form-control" placeholder="Nhập SĐT" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Ngày, Giờ đặt <span class="text-danger">*</span></label>
                            <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="input.ReservationTime" class="form-control" />
                        </div>
                        <div class="col-md-6 mt-3 mt-md-0">
                            <label class="form-label">Số khách <span class="text-danger">*</span></label>
                            <InputNumber @bind-Value="input.NumberOfGuests" class="form-control" min="1" max="50" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Chọn Bàn (không bắt buộc)</label>
                        <InputSelect @bind-Value="input.TableId" class="form-select">
                            <option value="">-- Chọn bàn --</option>
                            @if (tables != null)
                            {
                                @foreach (var t in tables)
                                {
                                    <option value="@t.TableId">Bàn @t.TableNumber (Tầng @t.FloorNumber) - Sức chứa: @t.RecommendedCapacity</option>
                                }
                            }
                        </InputSelect>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Ghi chú</label>
                        <InputTextArea @bind-Value="input.Note" class="form-control" rows="3" placeholder="Yêu cầu đặc biệt..." />
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a href="/order/reservationschedule" class="btn btn-light">Hủy</a>
                        <button type="submit" class="btn btn-primary px-4" disabled="@isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Đang lưu...</span>
                            }
                            else
                            {
                                <span>Lưu đặt bàn</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    private CreateReservationInput input = new();
    private List<TableModel>? tables;
    private bool isSubmitting = false;
    private AlertMessage alert = default!;

    protected override async Task OnInitializedAsync()
    {
        var result = await TableApiService.GetAllAsync();
        if (result != null && result.Success)
        {
            tables = result.List;
        }
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrEmpty(input.FullName) || string.IsNullOrEmpty(input.Phone))
        {
            alert.ShowError("Vui lòng điền đủ Tên và SĐT khách hàng.");
            return;
        }

        isSubmitting = true;
        alert.Hide();

        var result = await ReservationApiService.CreateAsync(input);

        if (result != null && result.Success)
        {
            NavigationManager.NavigateTo("/order/reservationschedule");
        }
        else
        {
            alert.ShowError(result?.Message ?? "Lỗi khi tạo đặt bàn.");
            isSubmitting = false;
        }
    }
}
