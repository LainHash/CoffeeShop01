@page "/Manager/Employees"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Manager")]
@inject IUserApiService UserApiService

<PageTitle>Quản lý Nhân viên - CoffeeShop</PageTitle>

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 position-relative overlay-bottom">
    <div class="d-flex flex-column align-items-center justify-content-center pt-0 pt-lg-5" style="min-height: 400px">
        <h1 class="display-4 mb-3 mt-0 mt-lg-5 text-white text-uppercase">Quản lý Nhân viên</h1>
        <div class="d-inline-flex mb-lg-5">
            <p class="m-0 text-white"><a class="text-white" href="/">Trang Chủ</a></p>
            <p class="m-0 text-white px-2">/</p>
            <p class="m-0 text-white">Quản lý Nhân viên</p>
        </div>
    </div>
</div>
<!-- Page Header End -->

<AlertMessage @ref="alert" />
<LoadingSpinner IsLoading="isLoading" />

@if (!isLoading && employees != null)
{
    <div class="container-fluid pt-5">
        <div class="container">
            <div class="section-title position-relative text-center mx-auto mb-5" style="max-width: 600px;">
                <h1 class="display-4">Quản Lý Nhân Viên</h1>
                <span class="text-primary font-weight-bold">Danh sách và thông tin nhân sự của quán</span>
            </div>

            <!-- Search and Filter Start -->
            <div class="row mb-4 justify-content-end">
                <div class="col-md-4">
                    <div class="input-group">
                        <input type="text" class="form-control border-primary" placeholder="Tìm kiếm theo tên, SĐT hoặc username..." 
                               @bind="searchTerm" @bind:event="oninput" />
                        <div class="input-group-append">
                            <span class="input-group-text bg-primary text-white"><i class="fa fa-search"></i></span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Search and Filter End -->

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
                    <h5 class="mb-0 text-white"><i class="fa fa-users mr-2 text-primary"></i>Danh Sách Nhân Viên</h5>
                    <a href="/Manager/Employees/Create" class="btn btn-primary btn-sm rounded-pill"><i class="fa fa-plus mr-1"></i>Thêm Mới</a>
                </div>
                <div class="card-body bg-light">
                    <div class="table-responsive">
                        <table class="table table-hover bg-white mb-0">
                            <thead class="thead-light">
                                <tr>
                                    <th scope="col" class="py-3">Họ và tên</th>
                                    <th scope="col" class="py-3">Tài khoản (Username)</th>
                                    <th scope="col" class="py-3">Chức vụ</th>
                                    <th scope="col" class="py-3">Số điện thoại</th>
                                    <th scope="col" class="py-3">Email</th>
                                    <th scope="col" class="py-3">Ngày tạo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (FilteredEmployees.Count == 0)
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-5 text-muted">
                                            <i class="fa fa-user-slash fa-3x mb-3 text-light"></i>
                                            <p class="mb-0">Không tìm thấy nhân viên nào phù hợp.</p>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var emp in FilteredEmployees)
                                    {
                                        <tr>
                                            <td class="font-weight-bold text-dark py-3">
                                                <i class="fa fa-user-circle text-primary mr-2"></i>@emp.FullName
                                            </td>
                                            <td class="py-3 text-secondary">@@@emp.User?.Username</td>
                                            <td class="py-3">
                                                <span class="badge badge-info px-3 py-1 font-weight-normal">
                                                    @emp.Position
                                                </span>
                                            </td>
                                            <td class="py-3">@emp.Phone</td>
                                            <td class="py-3">@emp.User?.Email</td>
                                            <td class="py-3 text-secondary">
                                                @(emp.User != null && emp.User.CreatedAt != default ? emp.User.CreatedAt.ToString("dd/MM/yyyy HH:mm") : "-")
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<EmployeeModel>? employees;
    private bool isLoading = true;
    private AlertMessage alert = default!;
    private string searchTerm = string.Empty;

    private List<EmployeeModel> FilteredEmployees => employees?
        .Where(e => string.IsNullOrWhiteSpace(searchTerm) || 
                    e.FullName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    e.Phone.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                    (e.User?.Username?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (e.Position?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .ToList() ?? new();

    protected override async Task OnInitializedAsync()
    {
        await LoadEmployees();
    }

    private async Task LoadEmployees()
    {
        isLoading = true;
        try
        {
            var result = await UserApiService.GetEmployeeListAsync();
            if (result != null && result.Success)
            {
                employees = result.List;
            }
            else
            {
                alert.ShowError(result?.Message ?? "Không thể tải danh sách nhân viên từ máy chủ.");
            }
        }
        catch (Exception ex)
        {
            alert.ShowError($"Đã xảy ra lỗi: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }
}
