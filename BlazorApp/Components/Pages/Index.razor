@page "/"
@using BlazorApp.Models.Products
@using BlazorApp.Services.Interfaces
@inject IApiService ApiService

<PageTitle>Home - KOPPEE Coffee Shop</PageTitle>

<!-- Carousel Start -->
<div class="container-fluid p-0 mb-5">
    <div id="blog-carousel" class="carousel slide overlay-bottom" data-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img class="w-100" src="/img/carousel-1.jpg" alt="KOPPEE Coffee">
                <div class="carousel-caption d-flex flex-column align-items-center justify-content-center">
                    <h2 class="text-primary font-weight-medium m-0">Chúng Tôi Đã Phục Vụ</h2>
                    <h1 class="display-1 text-white m-0">CÀ PHÊ</h1>
                    <h2 class="text-white m-0">* TỪ NĂM 1950 *</h2>
                </div>
            </div>
            <div class="carousel-item">
                <img class="w-100" src="/img/carousel-2.jpg" alt="KOPPEE Coffee">
                <div class="carousel-caption d-flex flex-column align-items-center justify-content-center">
                    <h2 class="text-primary font-weight-medium m-0">Chúng Tôi Đã Phục Vụ</h2>
                    <h1 class="display-1 text-white m-0">CÀ PHÊ</h1>
                    <h2 class="text-white m-0">* TỪ NĂM 1950 *</h2>
                </div>
            </div>
        </div>
        <a class="carousel-control-prev" href="#blog-carousel" data-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </a>
        <a class="carousel-control-next" href="#blog-carousel" data-slide="next">
            <span class="carousel-control-next-icon"></span>
        </a>
    </div>
</div>
<!-- Carousel End -->

<!-- About Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Về Chúng Tôi</h4>
            <h1 class="display-4">Phục Vụ Từ Năm 1950</h1>
        </div>
        <div class="row">
            <div class="col-lg-4 py-0 py-lg-5">
                <h1 class="mb-3">Câu Chuyện</h1>
                <h5 class="mb-3">Từ một tách cà phê đơn thuần đến điểm dừng chân yêu thích của những người yêu cà phê trên khắp Việt Nam.</h5>
                <p>KOPPEE ra đời từ niềm đam mê tạo ra tách cà phê hoàn hảo. Chúng tôi tuyển chọn những hạt cà phê ngon nhất từ các vùng cao nguyên Việt Nam và trên thế giới, rang xay hoàn hảo để mang đến cho bạn trải nghiệm khó quên mỗi lần thưởng thức.</p>
                <a href="/Home/About" class="btn btn-secondary font-weight-bold py-2 px-4 mt-2">Tìm Hiểu Thêm</a>
            </div>
            <div class="col-lg-4 py-5 py-lg-0" style="min-height: 500px;">
                <div class="position-relative h-100">
                    <img class="position-absolute w-100 h-100" src="/img/about.png" style="object-fit: cover;">
                </div>
            </div>
            <div class="col-lg-4 py-0 py-lg-5">
                <h1 class="mb-3">Tầm Nhìn</h1>
                <p>Chúng tôi tin rằng cà phê không chỉ là một thức uống—đó là một nghi thức, một khoảnh khắc kết nối. Tầm nhìn của chúng tôi là tạo ra một không gian ấm cúng, nơi mọi người có thể thưởng thức cà phê thượng hạng.</p>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>100% Hạt Cà Phê Hữu Cơ & Tươi</h5>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>Chuyên Gia Pha Chế Tại Chỗ</h5>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>Nguồn Cung Ứng Bền Vững</h5>
                <a href="/Product" class="btn btn-primary font-weight-bold py-2 px-4 mt-2">Xem Thực Đơn</a>
            </div>
        </div>
    </div>
</div>
<!-- About End -->

<!-- Service Start -->
<div class="container-fluid pt-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Dịch Vụ Của Chúng Tôi</h4>
            <h1 class="display-4">Hạt Cà Phê Tươi & Hữu Cơ</h1>
        </div>
        <div class="row">
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="/img/service-1.jpg" alt="Giao hàng">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-truck service-icon"></i>Giao Hàng Nhanh Chóng</h4>
                        <p class="m-0">Nhận cà phê yêu thích của bạn được giao nóng hổi và tươi mới đến tận cửa trong vòng 30 phút bất cứ nơi nào trong thành phố.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="/img/service-2.jpg" alt="Hạt cà phê">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-coffee service-icon"></i>Hạt Cà Phê Tươi</h4>
                        <p class="m-0">Được lấy từ những trang trại cao nguyên tốt nhất, hạt cà phê của chúng tôi được rang tươi hàng ngày để đảm bảo hương vị tối đa.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="/img/service-3.jpg" alt="Chất lượng">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-award service-icon"></i>Cà Phê Chất Lượng Nhất</h4>
                        <p class="m-0">Công thức đạt giải thưởng và sự am hiểu của các barista đảm bảo mỗi tách cà phê đều đáp ứng tiêu chuẩn chất lượng khắt khe.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="/img/service-4.jpg" alt="Đặt bàn">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-table service-icon"></i>Đặt Bàn Trực Tuyến</h4>
                        <p class="m-0">Đặt trước chỗ ngồi hoàn hảo của bạn trong vài giây và tận hưởng ưu đãi giảm giá 30% cho lần đặt bàn đầu tiên.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Service End -->

<!-- Offer Start -->
<div class="offer container-fluid my-5 py-5 text-center position-relative overlay-top overlay-bottom">
    <div class="container py-5">
        <h1 class="display-3 text-primary mt-3">GIẢM 50%</h1>
        <h1 class="text-white mb-3">Ưu Đãi Đặc Biệt Cuối Tuần</h1>
        <h4 class="text-white font-weight-normal mb-4 pb-3">Mỗi Thứ Bảy & Chủ Nhật — Chỉ Trong Thời Gian Có Hạn</h4>
        <form class="form-inline justify-content-center mb-4" @onsubmit:preventDefault>
            <div class="input-group">
                <input type="text" class="form-control p-4" placeholder="Email của bạn" style="height: 60px;">
                <div class="input-group-append">
                    <button class="btn btn-primary font-weight-bold px-4" type="submit">Đăng Ký</button>
                </div>
            </div>
        </form>
    </div>
</div>
<!-- Offer End -->

<!-- Menu Preview Start (Dynamic from API) -->
<div class="container-fluid pt-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Thực Đơn & Giá Cả</h4>
            <h1 class="display-4">Giá Cả Cạnh Tranh</h1>
        </div>

        @if (ApiError != null)
        {
            <div class="alert alert-warning">
                <i class="fa fa-exclamation-circle mr-2"></i>@ApiError
            </div>
        }

        <div class="row" id="menu-preview">
            @if (Products != null && Products.Any())
            {
                var preview = Products.Take(6).ToList();
                var hotGroup = preview.Take(3).ToList();
                var coldGroup = preview.Skip(3).Take(3).ToList();

                <div class="col-lg-6">
                    <h1 class="mb-5">Sản Phẩm Nổi Bật</h1>
                    @foreach (var p in hotGroup)
                    {
                        <div class="row align-items-center mb-5">
                            <div class="col-4 col-sm-3">
                                <img class="w-100 rounded-circle mb-3 mb-sm-0"
                                     src="@(string.IsNullOrEmpty(p.ImageUrl) ? "/img/menu-1.jpg" : p.ImageUrl)"
                                     alt="@p.ProductName"
                                     onerror="this.src='/img/menu-1.jpg'">
                                <h5 class="menu-price">@p.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</h5>
                            </div>
                            <div class="col-8 col-sm-9">
                                <h4>@p.ProductName</h4>
                                <p class="m-0">@(string.IsNullOrEmpty(p.Description) ? "Một sự kết hợp hoàn hảo được chế biến tỉ mỉ dành cho những người yêu cà phê." : p.Description)</p>
                                @if (!p.IsAvailable)
                                {
                                    <span class="badge badge-secondary mt-1">Hết hàng</span>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="col-lg-6">
                    <h1 class="mb-5">Lựa Chọn Phổ Biến</h1>
                    @foreach (var p in coldGroup)
                    {
                        <div class="row align-items-center mb-5">
                            <div class="col-4 col-sm-3">
                                <img class="w-100 rounded-circle mb-3 mb-sm-0"
                                     src="@(string.IsNullOrEmpty(p.ImageUrl) ? "/img/menu-2.jpg" : p.ImageUrl)"
                                     alt="@p.ProductName"
                                     onerror="this.src='/img/menu-2.jpg'">
                                <h5 class="menu-price">@p.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</h5>
                            </div>
                            <div class="col-8 col-sm-9">
                                <h4>@p.ProductName</h4>
                                <p class="m-0">@(string.IsNullOrEmpty(p.Description) ? "Một sự kết hợp hoàn hảo được chế biến tỉ mỉ dành cho những người yêu cà phê." : p.Description)</p>
                                @if (!p.IsAvailable)
                                {
                                    <span class="badge badge-secondary mt-1">Hết hàng</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else if (ApiError == null)
            {
                <div class="col-12 text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="sr-only">Loading...</span>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-3 mb-5">
            <a href="/Product" class="btn btn-primary font-weight-bold py-3 px-5">Xem Toàn Bộ Thực Đơn</a>
        </div>
    </div>
</div>
<!-- Menu Preview End -->

<!-- Reservation Start -->
<div class="container-fluid reservation position-relative overlay-top overlay-bottom my-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 my-5 my-lg-0">
                <div class="p-5">
                    <div class="mb-4">
                        <h1 class="display-3 text-primary">GIẢM 30%</h1>
                        <h1 class="text-white">Khi Đặt Bàn Trực Tuyến</h1>
                    </div>
                    <p class="text-white">Đặt bàn trực tuyến ngay để nhận ưu đãi độc quyền giảm giá 30% trên tổng hóa đơn của bạn. Chỉ áp dụng cho khách dùng tại chỗ.</p>
                    <ul class="list-inline text-white m-0">
                        <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>Xác nhận ngay lập tức</li>
                        <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>Không phí đặt bàn</li>
                        <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>Hủy bàn miễn phí</li>
                    </ul>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="text-center p-5" style="background: rgba(51, 33, 29, .8);">
                    <h1 class="text-white mb-4 mt-5">Đặt Bàn Ngay</h1>
                    <p class="text-white mb-4">
                        <a href="/Order/Reservation" class="btn btn-primary font-weight-bold py-3 px-5">
                            <i class="fa fa-calendar-check mr-2"></i>Tiến Hành Đặt Bàn
                        </a>
                    </p>
                    <p class="text-white">Hoặc gọi cho chúng tôi: <strong class="text-primary">+84 028 123 4567</strong></p>
                </div>
