<div class="top-row px-4 d-flex justify-content-between align-items-center shadow-sm">
    <div>
        <h4 class="mb-0 text-white">CoffeeShop Admin</h4>
    </div>
    
    <div class="d-flex align-items-center">
        <AuthorizeView>
            <Authorized>
                <div class="dropdown">
                    <button class="btn btn-dark dropdown-toggle text-white d-flex align-items-center gap-2 border-0" type="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-person-circle fs-5"></i>
                        <span>@context.User.Identity?.Name</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userMenu">
                        <li><span class="dropdown-item-text text-muted small">@RoleName</span></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <button class="dropdown-item text-danger d-flex align-items-center gap-2" @onclick="Logout">
                                <i class="bi bi-box-arrow-right"></i> Đăng xuất
                            </button>
                        </li>
                    </ul>
                </div>
            </Authorized>
            <NotAuthorized>
                <a href="/login" class="btn btn-outline-light btn-sm">Đăng nhập</a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    [Inject]
    private SessionService SessionService { get; set; } = default!;

    [Inject]
    private AppAuthStateProvider AuthStateProvider { get; set; } = default!;

    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    private string RoleName = "";

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var roleClaim = user.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role);
                RoleName = roleClaim?.Value ?? "User";
            }
        }
    }

    private async Task Logout()
    {
        await SessionService.ClearAsync();
        AuthStateProvider.NotifyUserLogout();
        NavigationManager.NavigateTo("/login");
    }
}
