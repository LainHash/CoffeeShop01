@page
@model RazorPage.Pages.Manager.Products.CreateModel
@{
    ViewData["Title"] = "Thêm Sản phẩm";
}
<vc:page-header title="Tạo sản phẩm mới"></vc:page-header>

<div class="container-xxl py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="bg-light rounded p-5">
                    <h1 class="display-5 mb-4">Thêm Sản phẩm Mới</h1>
                    
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger">@Model.ErrorMessage</div>
                    }

                    <form method="post">
                        <div class="row g-3">
                            <div class="col-sm-12">
                                <div class="form-floating">
                                    <input asp-for="Input.ProductName" class="form-control" placeholder="Tên sản phẩm" />
                                    <label asp-for="Input.ProductName">Tên sản phẩm</label>
                                    <span asp-validation-for="Input.ProductName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-floating">
                                    <select asp-for="Input.CategoryId" asp-items="Model.Categories" class="form-select">
                                        <option value="">-- Chọn danh mục --</option>
                                    </select>
                                    <label asp-for="Input.CategoryId">Danh mục</label>
                                    <span asp-validation-for="Input.CategoryId" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-floating">
                                    <input asp-for="Input.Price" type="number" step="0.01" class="form-control" placeholder="Giá" />
                                    <label asp-for="Input.Price">Giá (VNĐ)</label>
                                    <span asp-validation-for="Input.Price" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-sm-12">
                                <div class="form-floating">
                                    <input asp-for="Input.ImageUrl" class="form-control" placeholder="URL hình ảnh" />
                                    <label asp-for="Input.ImageUrl">URL Hình ảnh</label>
                                    <span asp-validation-for="Input.ImageUrl" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-sm-12">
                                <div class="form-floating">
                                    <textarea asp-for="Input.Description" class="form-control" style="height: 100px" placeholder="Mô tả"></textarea>
                                    <label asp-for="Input.Description">Mô tả sản phẩm</label>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-floating">
                                    <input asp-for="Input.UnitsInstock" type="number" class="form-control" placeholder="Số lượng tồn kho" />
                                    <label asp-for="Input.UnitsInstock">Số lượng tồn kho</label>
                                    <span asp-validation-for="Input.UnitsInstock" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-12 mt-4">
                                <button class="btn btn-primary py-3 px-5" type="submit">Thêm Sản phẩm</button>
                                <a asp-page="Index" class="btn btn-secondary py-3 px-5 ms-2">Hủy</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
