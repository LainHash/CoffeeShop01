@page
@model RazorPage.Pages.Manager.CheckoutModel
@{
    ViewData["Title"] = "Thanh toán hóa đơn #" + Model.Order?.OrderId;
}

<div class="container-fluid pt-5">
    <div class="container">
        <!-- Back Link -->
        <div class="mb-4">
            <a href="/Manager/Details?id=@Model.Order?.PublicId" class="btn btn-outline-secondary rounded-pill">
                <i class="fa fa-arrow-left mr-1"></i> Quay lại chi tiết hóa đơn
            </a>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fa fa-exclamation-circle mr-2"></i> @Model.ErrorMessage
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (Model.Order != null)
        {
            <form method="post">
                <div class="row">
                    <!-- Left: Payment Form -->
                    <div class="col-lg-7 mb-4">
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-header bg-dark text-white py-3">
                                <h5 class="mb-0 text-white"><i class="fa fa-credit-card mr-2 text-primary"></i>Phương thức thanh toán</h5>
                            </div>
                            <div class="card-body bg-white p-4">
                                <label class="text-muted mb-3 d-block">Vui lòng chọn hình thức thanh toán:</label>
                                
                                <div class="row mb-4">
                                    <!-- Cash Option -->
                                    <div class="col-md-4 mb-3">
                                        <div class="payment-method-card text-center p-3 border rounded cursor-pointer active-method" data-value="Cash">
                                            <i class="fa fa-money-bill-wave fa-2x text-success mb-2"></i>
                                            <h6 class="font-weight-bold text-dark mb-0">Tiền mặt</h6>
                                            <small class="text-muted">Cash</small>
                                        </div>
                                    </div>
                                    
                                    <!-- Credit Card Option -->
                                    <div class="col-md-4 mb-3">
                                        <div class="payment-method-card text-center p-3 border rounded cursor-pointer" data-value="Credit Card">
                                            <i class="fa fa-credit-card fa-2x text-primary mb-2"></i>
                                            <h6 class="font-weight-bold text-dark mb-0">Thẻ tín dụng</h6>
                                            <small class="text-muted">Credit Card</small>
                                        </div>
                                    </div>

                                    <!-- Bank Transfer Option -->
                                    <div class="col-md-4 mb-3">
                                        <div class="payment-method-card text-center p-3 border rounded cursor-pointer" data-value="Bank Transfer">
                                            <i class="fa fa-university fa-2x text-info mb-2"></i>
                                            <h6 class="font-weight-bold text-dark mb-0">Chuyển khoản</h6>
                                            <small class="text-muted">Bank Transfer</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Hidden input to hold chosen method -->
                                <input type="hidden" asp-for="PaymentMethod" id="selectedPaymentMethod" value="Cash" />

                                <!-- Notes area -->
                                <div class="form-group">
                                    <label asp-for="Note" class="font-weight-bold text-dark">Ghi chú thanh toán</label>
                                    <textarea asp-for="Note" class="form-control" rows="3" placeholder="Nhập ghi chú giao dịch nếu có (ví dụ: số thẻ, mã giao dịch, khách đưa 500k thối 20k...)"></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- Bank Transfer details (visually shown when Bank Transfer selected) -->
                        <div id="bankTransferDetails" class="card border-0 shadow-sm mb-4 bg-light" style="display: none;">
                            <div class="card-body p-4 text-center">
                                <h6 class="font-weight-bold text-dark mb-3"><i class="fa fa-qrcode mr-2 text-primary"></i>Thông tin chuyển khoản nhanh</h6>
                                <p class="text-muted small mb-2">Quét mã QR bên dưới để thanh toán nhanh:</p>
                                
                                <div class="bg-white p-3 d-inline-block rounded border mb-3">
                                    <!-- Generates VietQR standard link for bank transfer -->
                                    <img src="https://img.vietqr.io/image/MB-123456789999-qr_only.png?amount=@((int)Model.Order.TotalAmount)&addInfo=KOPPEE%20HD%20@Model.Order.OrderId" 
                                         alt="Mã QR chuyển khoản" 
                                         style="max-width: 200px; height: auto;" />
                                </div>
                                <div class="text-left max-w-sm mx-auto small">
                                    <div><strong>Ngân hàng:</strong> MB Bank (NHTMCP Quân Đội)</div>
                                    <div><strong>Số tài khoản:</strong> 123456789999</div>
                                    <div><strong>Chủ tài khoản:</strong> COFFEE SHOP KOPPEE</div>
                                    <div><strong>Số tiền:</strong> <span class="text-primary font-weight-bold">@Model.Order.TotalAmount.ToString("N0") đ</span></div>
                                    <div><strong>Nội dung:</strong> <span class="text-dark font-weight-bold">KOPPEE HD @Model.Order.OrderId</span></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right: Order Summary -->
                    <div class="col-lg-5 mb-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-dark text-white py-3">
                                <h5 class="mb-0 text-white"><i class="fa fa-receipt mr-2 text-primary"></i>Tóm tắt hóa đơn</h5>
                            </div>
                            <div class="card-body bg-white p-4">
                                <div class="mb-3 pb-3 border-bottom">
                                    <div class="d-flex justify-content-between text-muted small mb-1">
                                        <span>Mã hóa đơn:</span>
                                        <span class="font-weight-bold text-dark">#@Model.Order.OrderId</span>
                                    </div>
                                    <div class="d-flex justify-content-between text-muted small mb-1">
                                        <span>Bàn phục vụ:</span>
                                        <span class="font-weight-bold text-dark">@(Model.Order.TableNumber > 0 ? $"Bàn {Model.Order.TableNumber} (Tầng {Model.Order.FloorNumber})" : "Mang đi")</span>
                                    </div>
                                    <div class="d-flex justify-content-between text-muted small">
                                        <span>Nhân viên:</span>
                                        <span class="font-weight-bold text-dark">@Model.Order.EmployeeName</span>
                                    </div>
                                </div>

                                <h6 class="font-weight-bold text-dark mb-3">Sản phẩm đã chọn:</h6>
                                <div class="order-items-list mb-3" style="max-height: 200px; overflow-y: auto;">
                                    @foreach (var item in Model.Order.OrderDetails)
                                    {
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <div class="small">
                                                <span class="font-weight-bold text-dark">@item.ProductName</span>
                                                <span class="text-muted ml-1">x @item.Quantity</span>
                                            </div>
                                            <span class="small font-weight-bold text-dark">@item.LineTotal.ToString("N0") đ</span>
                                        </div>
                                    }
                                </div>

                                <div class="pt-3 border-top">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="text-muted">Tạm tính:</span>
                                        <span class="font-weight-bold">@Model.Order.SubTotal.ToString("N0") đ</span>
                                    </div>
                                    @if (Model.Order.DiscountId.HasValue && Model.Order.DiscountId.Value > 0)
                                    {
                                        <div class="d-flex justify-content-between mb-2 text-success">
                                            <span>Mã giảm giá (@Model.Order.DiscountCode):</span>
                                            <span>- @((Model.Order.SubTotal - Model.Order.TotalAmount).ToString("N0")) đ</span>
                                        </div>
                                    }
                                    <hr />
                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                        <h5 class="mb-0 text-dark font-weight-bold">Tổng thanh toán:</h5>
                                        <h3 class="mb-0 text-primary font-weight-bold">@Model.Order.TotalAmount.ToString("N0") đ</h3>
                                    </div>

                                    <button type="submit" class="btn btn-primary btn-block btn-lg py-3 rounded-pill shadow-sm font-weight-bold">
                                        <i class="fa fa-check-circle mr-2"></i>XÁC NHẬN & HOÀN TẤT
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        }
    </div>
</div>

<style>
    .payment-method-card {
        transition: all 0.3s ease;
        border-width: 2px !important;
    }
    .payment-method-card:hover {
        border-color: #DA9F5B !important;
        transform: translateY(-2px);
    }
    .active-method {
        border-color: #DA9F5B !important;
        background-color: rgba(218, 159, 91, 0.05);
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }
    .cursor-pointer {
        cursor: pointer;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            $(".payment-method-card").on("click", function() {
                // Remove active class from all
                $(".payment-method-card").removeClass("active-method");
                
                // Add active class to clicked card
                $(this).addClass("active-method");
                
                // Set hidden input value
                var value = $(this).attr("data-value");
                $("#selectedPaymentMethod").val(value);

                // Toggle Bank Transfer Details
                if (value === "Bank Transfer") {
                    $("#bankTransferDetails").slideDown(300);
                } else {
                    $("#bankTransferDetails").slideUp(300);
                }
            });
        });
    </script>
}
