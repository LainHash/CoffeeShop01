@page
@model RazorPage.Pages.Order.ReservationModel
@{
    ViewData["Title"] = "Đặt Bàn - KOPPEE Coffee Shop";
    ViewData["ActivePage"] = "Reservation";
}

<vc:page-header title="Đặt Bàn"></vc:page-header>

@if (Model.IsStaff)
{
    <!-- ===== STAFF FORM VIEW ===== -->
    <div class="container-fluid py-5">
        <div class="container">
            <div class="reservation position-relative overlay-top overlay-bottom">
                <div class="row align-items-center">
                    <!-- Left Info Panel -->
                    <div class="col-lg-6 my-5 my-lg-0">
                        <div class="p-5">
                            <div class="mb-4">
                                <span class="badge badge-warning text-dark px-3 py-2 mb-3 font-weight-bold" style="font-size:0.85rem; border-radius:20px;">
                                    <i class="fa fa-user-tie mr-1"></i> Chế độ Nhân Viên
                                </span>
                                <h1 class="display-3 text-primary">ĐẶT BÀN</h1>
                                <h1 class="text-white">Cho Khách Hàng</h1>
                            </div>
                            <p class="text-white">Điền đầy đủ thông tin để đặt bàn cho khách. Hệ thống sẽ ghi nhận ngay lập tức và gửi xác nhận.</p>
                            <ul class="list-inline text-white m-0">
                                <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>Xác nhận đặt bàn ngay lập tức</li>
                                <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>Không phí hủy bàn</li>
                                <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>Ưu đãi độc quyền cho thành viên</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Right Form Panel -->
                    <div class="col-lg-6">
                        <div class="text-center p-5" style="background: rgba(51, 33, 29, .85); border-radius: 12px;">
                            <h2 class="text-white mb-4">
                                <i class="fa fa-calendar-alt text-primary mr-2"></i>Thông Tin Đặt Bàn
                            </h2>

                            @if (Model.SuccessMessage != null)
                            {
                                <div class="alert alert-success text-left" style="border-radius:10px;">
                                    <i class="fa fa-check-circle mr-2"></i>@Model.SuccessMessage
                                </div>
                            }
                            @if (Model.ErrorMessage != null)
                            {
                                <div class="alert alert-danger text-left" style="border-radius:10px;">
                                    <i class="fa fa-exclamation-circle mr-2"></i>@Model.ErrorMessage
                                </div>
                            }

                            <form method="post" class="mb-3 text-left" id="reservation-form">
                                @Html.AntiForgeryToken()

                                <!-- Customer Name -->
                                <div class="form-group">
                                    <label class="text-white small font-weight-bold mb-1">
                                        <i class="fa fa-user text-primary mr-1"></i>Họ và Tên Khách Hàng <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Input.FullName"
                                           type="text"
                                           class="form-control bg-transparent border-primary p-4 text-white"
                                           placeholder="Nguyễn Văn A"
                                           required />
                                    <span asp-validation-for="Input.FullName" class="text-warning small"></span>
                                </div>

                                <!-- Email -->
                                <div class="form-group">
                                    <label class="text-white small font-weight-bold mb-1">
                                        <i class="fa fa-envelope text-primary mr-1"></i>Email Khách Hàng <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Input.Email"
                                           type="email"
                                           class="form-control bg-transparent border-primary p-4 text-white"
                                           placeholder="ten@email.com"
                                           required />
                                    <span asp-validation-for="Input.Email" class="text-warning small"></span>
                                </div>

                                <!-- Phone -->
                                <div class="form-group">
                                    <label class="text-white small font-weight-bold mb-1">
                                        <i class="fa fa-phone text-primary mr-1"></i>Số Điện Thoại <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Input.Phone"
                                           type="tel"
                                           class="form-control bg-transparent border-primary p-4 text-white"
                                           placeholder="0912 345 678"
                                           required />
                                </div>

                                <!-- Date & Time Row -->
                                <div class="form-row">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="text-white small font-weight-bold mb-1">
                                                <i class="fa fa-calendar text-primary mr-1"></i>Ngày <span class="text-danger">*</span>
                                            </label>
                                            <div class="date" id="date" data-target-input="nearest">
                                                <input asp-for="Input.Date"
                                                       type="text"
                                                       class="form-control bg-transparent border-primary p-4 datetimepicker-input text-white"
                                                       placeholder="dd/mm/yyyy"
                                                       data-target="#date"
                                                       data-toggle="datetimepicker" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="text-white small font-weight-bold mb-1">
                                                <i class="fa fa-clock text-primary mr-1"></i>Giờ <span class="text-danger">*</span>
                                            </label>
                                            <div class="time" id="time" data-target-input="nearest">
                                                <input asp-for="Input.Time"
                                                       type="text"
                                                       class="form-control bg-transparent border-primary p-4 datetimepicker-input text-white"
                                                       placeholder="HH:MM"
                                                       data-target="#time"
                                                       data-toggle="datetimepicker" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Number of Guests -->
                                <div class="form-group">
                                    <label class="text-white small font-weight-bold mb-1">
                                        <i class="fa fa-users text-primary mr-1"></i>Số Lượng Khách <span class="text-danger">*</span>
                                    </label>
                                    <select asp-for="Input.NumberOfGuests"
                                            class="custom-select bg-transparent border-primary px-4 text-white"
                                            style="height: 56px;">
                                        <option value="" disabled selected>Chọn số người</option>
                                        <option value="1">1 Người</option>
                                        <option value="2">2 Người</option>
                                        <option value="3">3 Người</option>
                                        <option value="4">4 Người</option>
                                        <option value="5">5 Người</option>
                                        <option value="6">6 Người</option>
                                        <option value="7">7+ Người</option>
                                    </select>
                                </div>

                                <!-- Note -->
                                <div class="form-group">
                                    <label class="text-white small font-weight-bold mb-1">
                                        <i class="fa fa-sticky-note text-primary mr-1"></i>Ghi Chú
                                    </label>
                                    <textarea asp-for="Input.Note"
                                              class="form-control bg-transparent border-primary p-4 text-white"
                                              placeholder="Yêu cầu đặc biệt (vị trí bàn, dịp đặc biệt, dị ứng thực phẩm...)"
                                              rows="3"></textarea>
                                </div>

                                <button class="btn btn-primary btn-block font-weight-bold py-3" type="submit" id="submit-btn" style="border-radius:8px; font-size:1.05rem;">
                                    <i class="fa fa-calendar-check mr-2"></i>Xác Nhận Đặt Bàn
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- ===== END STAFF FORM VIEW ===== -->
}
else
{
    <partial name="_CustomerContact" />
}

@section Scripts {
    @if (Model.IsStaff)
    {
        <script>
            $(function () {
                // Date picker
                $('#date').datetimepicker({
                    format: 'L',
                    minDate: new Date()
                });
                // Time picker
                $('#time').datetimepicker({
                    format: 'LT'
                });

                // Form submit loading state
                $('#reservation-form').on('submit', function () {
                    $('#submit-btn').html('<i class="fa fa-spinner fa-spin mr-2"></i>Đang xử lý...').prop('disabled', true);
                });
            });
        </script>
    }
}
