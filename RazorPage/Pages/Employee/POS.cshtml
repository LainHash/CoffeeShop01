@page
@model RazorPage.Pages.Employee.POSModel
@using RazorPage.Helpers.Constants.Orders
@{
    ViewData["Title"] = "Point of Sale (POS)";
    Layout = "~/Pages/Shared/_Layout.cshtml";

    // Group tables by floor for tab rendering
    var tablesByFloor = Model.Tables
        .GroupBy(t => t.FloorNumber)
        .OrderBy(g => g.Key)
        .ToList();
}
<vc:page-header title="Hệ thống POS"></vc:page-header>

<div class="container-fluid pt-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Hệ thống POS</h4>
            <h1 class="display-4">Tạo Hóa Đơn Mới</h1>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success">@Model.SuccessMessage</div>
        }

        <div class="row">
            <!-- ── Product Grid ── -->
            <div class="col-lg-8">
                <h4 class="mb-4">Danh sách sản phẩm</h4>
                <div class="row">
                    @foreach (var p in Model.Products)
                    {
                        <div class="col-md-4 mb-4">
                            <div class="card h-100 shadow-sm">
                                <img src="@p.ImageUrl" class="card-img-top" alt="@p.ProductName" style="height: 200px; object-fit: cover;">
                                <div class="card-body text-center">
                                    <h5 class="card-title">@p.ProductName</h5>
                                    <p class="card-text font-weight-bold text-primary">@p.Price.ToString("N0") VNĐ</p>
                                    <button type="button" class="btn btn-outline-primary btn-sm add-to-cart-btn"
                                            data-id="@p.ProductId"
                                            data-name="@p.ProductName"
                                            data-price="@p.Price">
                                        <i class="fa fa-plus"></i> Thêm món
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- ── Order Sidebar ── -->
            <div class="col-lg-4">
                <h4 class="mb-4">Chi tiết hóa đơn</h4>
                <div class="card shadow-sm">
                    <div class="card-body">
                        <form method="post" id="posForm">

                            <!-- ══ Table Picker (floor tabs + card grid) ══ -->
                            <div class="form-group mb-3">
                                <label class="fw-bold mb-2">
                                    <i class="fa fa-table me-1"></i> Chọn bàn phục vụ
                                </label>

                                @if (!tablesByFloor.Any())
                                {
                                    <div class="alert alert-warning py-2">Chưa có bàn nào.</div>
                                }
                                else
                                {
                                    <!-- Floor tab buttons -->
                                    <div class="floor-tabs" id="floorTabs">
                                        @foreach (var floor in tablesByFloor)
                                        {
                                            <button type="button"
                                                    class="floor-tab-btn @(floor == tablesByFloor.First() ? "active" : "")"
                                                    data-floor="@floor.Key">
                                                Tầng @floor.Key
                                            </button>
                                        }
                                    </div>

                                    <!-- Table card panels, one per floor -->
                                    @foreach (var floor in tablesByFloor)
                                    {
                                        <div class="table-floor-panel @(floor == tablesByFloor.First() ? "active" : "")"
                                             id="floor-panel-@floor.Key">
                                            <div class="row g-2">
                                                @foreach (var t in floor.OrderBy(x => x.TableNumber))
                                                {
                                                    <div class="col-4">
                                                        <div class="table-card"
                                                             data-table-id="@t.TableId"
                                                             data-table-num="@t.TableNumber"
                                                             data-floor="@t.FloorNumber"
                                                             data-shape="@t.Shape">
                                                            <span class="table-icon">🪑</span>
                                                            <div class="table-num">Bàn @t.TableNumber</div>
                                                            @if (!string.IsNullOrEmpty(t.Shape))
                                                            {
                                                                <div class="table-shape">@t.Shape</div>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }

                                    <!-- Badge shows currently selected table -->
                                    <div id="selected-table-badge">
                                        <i class="fa fa-check-circle me-1"></i>
                                        <span id="selected-table-text">Chưa chọn bàn</span>
                                    </div>
                                }

                                <!-- Hidden input carries the TableId on submit -->
                                <input type="hidden" asp-for="Input.TableId" id="selected-table-id" value="0" />
                            </div>
                            <!-- ════════════════════════════════════════════ -->

                            <hr />
                            <h5 class="mb-3">Các món đã chọn</h5>
                            <div id="cart-items">
                                <p class="text-muted text-center empty-cart-msg">Chưa có món nào.</p>
                                <!-- Cart items will be appended here by JS -->
                            </div>

                            <hr />
                            <div class="d-flex justify-content-between font-weight-bold mb-3">
                                <span>Tổng cộng:</span>
                                <span id="cart-total" class="text-primary">0 VNĐ</span>
                            </div>

                            <div class="form-group">
                                <label>Giảm giá</label>
                                <select asp-for="Input.DiscountId"
                                        class="form-control"
                                        id="discount-select"
                                        onchange="updateCartUI()">
                                    <option value="" data-type="none" data-value="0">-- Không có --</option>
                                    @foreach (var d in Model.Discounts)
                                    {
                                        <option value="@d.DiscountId"
                                                data-type="@d.Type"
                                                data-value="@d.Value">
                                            @d.DiscountCode - @(d.Type == "Percent" ? d.Value * 100 + "%" : d.Value.ToString("N0") + " VNĐ")
                                        </option>
                                    }
                                </select>
                            </div>

                            <hr />
                            <div class="d-flex justify-content-between font-weight-bold mb-3">
                                <span>Thành tiền:</span>
                                <span id="final-total" class="text-danger h5">0 VNĐ</span>
                            </div>

                            <button type="submit"
                                    class="btn btn-primary btn-block font-weight-bold py-3 mt-4"
                                    id="submitOrderBtn" disabled>
                                XÁC NHẬN TẠO HÓA ĐƠN
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        /* ═══════════════════════════════════════
           Floor-tab + Table-card picker
        ═══════════════════════════════════════ */
        (function () {
            // Tab switching
            document.querySelectorAll('.floor-tab-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var floor = this.getAttribute('data-floor');

                    // Toggle active tab button
                    document.querySelectorAll('.floor-tab-btn').forEach(function (b) {
                        b.classList.remove('active');
                    });
                    this.classList.add('active');

                    // Show matching panel
                    document.querySelectorAll('.table-floor-panel').forEach(function (p) {
                        p.classList.remove('active');
                    });
                    var panel = document.getElementById('floor-panel-' + floor);
                    if (panel) panel.classList.add('active');
                });
            });

            // Table card selection
            document.querySelectorAll('.table-card').forEach(function (card) {
                card.addEventListener('click', function () {
                    var tableId  = this.getAttribute('data-table-id');
                    var tableNum = this.getAttribute('data-table-num');
                    var floor    = this.getAttribute('data-floor');

                    // Deselect all cards
                    document.querySelectorAll('.table-card').forEach(function (c) {
                        c.classList.remove('selected');
                    });
                    // Select clicked card
                    this.classList.add('selected');

                    // Update hidden input
                    document.getElementById('selected-table-id').value = tableId;

                    // Show badge
                    var badge = document.getElementById('selected-table-badge');
                    var text  = document.getElementById('selected-table-text');
                    badge.style.display = 'block';
                    text.textContent    = 'Bàn ' + tableNum + ' – Tầng ' + floor;

                    checkSubmitBtn();
                });
            });

            // Re-evaluate submit button when cart or table changes
            window.checkSubmitBtn = function () {
                var tableId  = document.getElementById('selected-table-id').value;
                var hasTable = tableId && tableId !== '0';
                var hasCart  = cart.length > 0;
                document.getElementById('submitOrderBtn').disabled = !(hasTable && hasCart);
            };
        })();

        /* ═══════════════════════════════════════
           Cart logic
        ═══════════════════════════════════════ */
        let cart = [];

        function updateCartUI() {
            const container      = document.getElementById('cart-items');
            const subtotalEl     = document.getElementById('cart-total');
            const finalTotalEl   = document.getElementById('final-total');
            const discountSelect = document.getElementById('discount-select');

            container.innerHTML = '';
            let subtotal = 0;

            if (cart.length === 0) {
                container.innerHTML = '<p class="text-muted text-center empty-cart-msg">Chưa có món nào.</p>';
            } else {
                cart.forEach((item, index) => {
                    const itemTotal = item.price * item.quantity;
                    subtotal += itemTotal;

                    const itemHtml = `
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div>
                                <h6 class="my-0">${item.name}</h6>
                                <small class="text-muted">${item.price.toLocaleString()} x ${item.quantity}</small>
                            </div>
                            <div class="d-flex align-items-center">
                                <span class="mr-3">${itemTotal.toLocaleString()} đ</span>
                                <button type="button" class="btn btn-sm btn-danger px-2 py-1 remove-item-btn" data-index="${index}">
                                    <i class="fa fa-times"></i>
                                </button>
                            </div>
                            <input type="hidden" name="Input.OrderDetails[${index}].ProductId" value="${item.id}" />
                            <input type="hidden" name="Input.OrderDetails[${index}].Quantity"   value="${item.quantity}" />
                        </div>
                    `;
                    container.insertAdjacentHTML('beforeend', itemHtml);
                });
            }

            subtotalEl.innerText = subtotal.toLocaleString() + ' VNĐ';

            // Discount
            let finalTotal = subtotal;
            if (discountSelect.selectedIndex > 0) {
                const option = discountSelect.options[discountSelect.selectedIndex];
                const type   = option.getAttribute('data-type').toLowerCase();
                const value  = parseFloat(option.getAttribute('data-value'));
                if (type === "flat")    finalTotal -= value;
                else if (type === "percent") finalTotal -= subtotal * value;
            }
            if (finalTotal < 0) finalTotal = 0;
            finalTotalEl.innerText = finalTotal.toLocaleString() + ' VNĐ';

            // Remove button handlers
            document.querySelectorAll('.remove-item-btn').forEach(btn => {
                btn.addEventListener('click', function () {
                    const idx = parseInt(this.getAttribute('data-index'));
                    cart.splice(idx, 1);
                    updateCartUI();
                    checkSubmitBtn();
                });
            });

            checkSubmitBtn();
        }

        document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                const id    = parseInt(this.getAttribute('data-id'));
                const name  = this.getAttribute('data-name');
                const price = parseFloat(this.getAttribute('data-price'));

                const existingItem = cart.find(x => x.id === id);
                if (existingItem) {
                    existingItem.quantity += 1;
                } else {
                    cart.push({ id, name, price, quantity: 1 });
                }

                updateCartUI();
            });
        });
    </script>
}
