@page
@model RazorPage.Pages.ReservationModel
@{
    ViewData["Title"] = "Reservation - KOPPEE Coffee Shop";
    ViewData["ActivePage"] = "Reservation";
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 position-relative overlay-bottom">
    <div class="d-flex flex-column align-items-center justify-content-center pt-0 pt-lg-5" style="min-height: 400px">
        <h1 class="display-4 mb-3 mt-0 mt-lg-5 text-white text-uppercase">Reservation</h1>
        <div class="d-inline-flex mb-lg-5">
            <p class="m-0 text-white"><a class="text-white" asp-page="/Index">Home</a></p>
            <p class="m-0 text-white px-2">/</p>
            <p class="m-0 text-white">Reservation</p>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Reservation Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="reservation position-relative overlay-top overlay-bottom">
            <div class="row align-items-center">
                <div class="col-lg-6 my-5 my-lg-0">
                    <div class="p-5">
                        <div class="mb-4">
                            <h1 class="display-3 text-primary">30% OFF</h1>
                            <h1 class="text-white">For Online Reservation</h1>
                        </div>
                        <p class="text-white">Book your table online and enjoy exclusive discounts. Our team will confirm your reservation within 15 minutes.</p>
                        <ul class="list-inline text-white m-0">
                            <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>Instant booking confirmation</li>
                            <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>No cancellation fee</li>
                            <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>Exclusive member discounts</li>
                        </ul>
                    </div>
                </div>
                <div class="col-lg-6">
                    <div class="text-center p-5" style="background: rgba(51, 33, 29, .8);">
                        <h1 class="text-white mb-4 mt-5">Book Your Table</h1>

                        @if (Model.SuccessMessage != null)
                        {
                            <div class="alert alert-success">
                                <i class="fa fa-check-circle mr-2"></i>@Model.SuccessMessage
                            </div>
                        }
                        @if (Model.ErrorMessage != null)
                        {
                            <div class="alert alert-danger">
                                <i class="fa fa-exclamation-circle mr-2"></i>@Model.ErrorMessage
                            </div>
                        }

                        <form method="post" class="mb-5" id="reservation-form">
                            @Html.AntiForgeryToken()
                            <div class="form-group">
                                <input asp-for="Input.FullName"
                                       type="text"
                                       class="form-control bg-transparent border-primary p-4 text-white"
                                       placeholder="Your Full Name"
                                       required />
                                <span asp-validation-for="Input.FullName" class="text-warning small"></span>
                            </div>
                            <div class="form-group">
                                <input asp-for="Input.Email"
                                       type="email"
                                       class="form-control bg-transparent border-primary p-4 text-white"
                                       placeholder="Your Email"
                                       required />
                                <span asp-validation-for="Input.Email" class="text-warning small"></span>
                            </div>
                            <div class="form-group">
                                <input asp-for="Input.Phone"
                                       type="tel"
                                       class="form-control bg-transparent border-primary p-4 text-white"
                                       placeholder="Your Phone Number"
                                       required />
                            </div>
                            <div class="form-group">
                                <div class="date" id="date" data-target-input="nearest">
                                    <input asp-for="Input.Date"
                                           type="text"
                                           class="form-control bg-transparent border-primary p-4 datetimepicker-input text-white"
                                           placeholder="Date"
                                           data-target="#date"
                                           data-toggle="datetimepicker" />
                                </div>
                            </div>
                            <div class="form-group">
                                <div class="time" id="time" data-target-input="nearest">
                                    <input asp-for="Input.Time"
                                           type="text"
                                           class="form-control bg-transparent border-primary p-4 datetimepicker-input text-white"
                                           placeholder="Time"
                                           data-target="#time"
                                           data-toggle="datetimepicker" />
                                </div>
                            </div>
                            <div class="form-group">
                                <select asp-for="Input.NumberOfGuests"
                                        class="custom-select bg-transparent border-primary px-4 text-white"
                                        style="height: 49px;">
                                    <option value="" disabled selected>Number of Guests</option>
                                    <option value="1">1 Person</option>
                                    <option value="2">2 Persons</option>
                                    <option value="3">3 Persons</option>
                                    <option value="4">4 Persons</option>
                                    <option value="5">5 Persons</option>
                                    <option value="6">6 Persons</option>
                                    <option value="7">7+ Persons</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <textarea asp-for="Input.Note"
                                          class="form-control bg-transparent border-primary p-4 text-white"
                                          placeholder="Special requests (optional)"
                                          rows="3"></textarea>
                            </div>
                            <div>
                                <button class="btn btn-primary btn-block font-weight-bold py-3" type="submit" id="submit-btn">
                                    <i class="fa fa-calendar-check mr-2"></i>Book Now
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Reservation End -->

@section Scripts {
    <script>
        $(function () {
            // Date picker
            $('#date').datetimepicker({
                format: 'L',
                minDate: new Date()
            });
            // Time picker
            $('#time').datetimepicker({
                format: 'LT'
            });

            // Form submit loading state
            $('#reservation-form').on('submit', function () {
                $('#submit-btn').html('<i class="fa fa-spinner fa-spin mr-2"></i>Processing...').prop('disabled', true);
            });
        });
    </script>
}
