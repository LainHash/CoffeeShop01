@page
@model RazorPage.Pages.Auth.ProfileModel
@{
    ViewData["Title"] = "Hồ sơ của tôi";
}

<div class="container-xxl py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="bg-light rounded p-5">
                    <h1 class="display-5 mb-4 text-center">Hồ sơ cá nhân</h1>
                    
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger">@Model.ErrorMessage</div>
                    }
                    else
                    {
                        <div class="row g-4">
                            <div class="col-md-6">
                                <h5>Họ và tên</h5>
                                <p class="text-muted">@Model.ProfileData.FullName</p>
                            </div>
                            <div class="col-md-6">
                                <h5>Vai trò</h5>
                                <p class="text-muted">@Model.ProfileData.RoleName</p>
                            </div>
                            <div class="col-md-6">
                                <h5>Email</h5>
                                <p class="text-muted">@Model.ProfileData.Email</p>
                            </div>
                            <div class="col-md-6">
                                <h5>Số điện thoại</h5>
                                <p class="text-muted">@Model.ProfileData.Phone</p>
                            </div>
                            <div class="col-md-6">
                                <h5>Tên đăng nhập</h5>
                                <p class="text-muted">@Model.ProfileData.Username</p>
                            </div>
                            <div class="col-md-6">
                                <h5>Ngày tham gia</h5>
                                <p class="text-muted">@Model.ProfileData.CreatedAt.ToString("dd/MM/yyyy")</p>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.ProfileData.Position))
                            {
                                <div class="col-md-6">
                                    <h5>Chức vụ</h5>
                                    <p class="text-muted">@Model.ProfileData.Position</p>
                                </div>
                            }
                        </div>
                        <div class="text-center mt-5">
                            @if (Model.ProfileData.RoleName == "Khách hàng")
                            {
                                <a asp-page="/Index" class="btn btn-secondary py-2 px-4">Về trang chủ</a>
                            }
                            else
                            {
                                <a asp-page="/Employee/POS" class="btn btn-secondary py-2 px-4">Về trang POS</a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
