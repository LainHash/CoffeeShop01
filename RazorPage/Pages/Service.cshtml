@page
@{
    ViewData["Title"] = "Services - KOPPEE Coffee Shop";
    ViewData["ActivePage"] = "Service";
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 position-relative overlay-bottom">
    <div class="d-flex flex-column align-items-center justify-content-center pt-0 pt-lg-5" style="min-height: 400px">
        <h1 class="display-4 mb-3 mt-0 mt-lg-5 text-white text-uppercase">Our Services</h1>
        <div class="d-inline-flex mb-lg-5">
            <p class="m-0 text-white"><a class="text-white" asp-page="/Index">Home</a></p>
            <p class="m-0 text-white px-2">/</p>
            <p class="m-0 text-white">Services</p>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Services Start -->
<div class="container-fluid pt-5 pb-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Our Services</h4>
            <h1 class="display-4">Fresh &amp; Organic Beans</h1>
        </div>
        <div class="row">
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="~/img/service-1.jpg" alt="Delivery">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-truck service-icon"></i>Fastest Door Delivery</h4>
                        <p class="m-0">Get your favourite coffee delivered hot and fresh to your doorstep within 30 minutes, anywhere in the city. Track your order in real time.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="~/img/service-2.jpg" alt="Beans">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-coffee service-icon"></i>Fresh Coffee Beans</h4>
                        <p class="m-0">Sourced directly from highland farms in Da Lat and Buon Ma Thuot, our beans are roasted fresh every morning for maximum flavour.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="~/img/service-3.jpg" alt="Quality">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-award service-icon"></i>Best Quality Coffee</h4>
                        <p class="m-0">Award-winning recipes perfected over 70+ years. Every cup is crafted by our certified baristas to bring you a consistently exceptional experience.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="~/img/service-4.jpg" alt="Booking">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-table service-icon"></i>Online Table Booking</h4>
                        <p class="m-0">Reserve your perfect table in seconds. Get 30% off when you book online. Perfect for business meetings, dates, and family gatherings.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center mt-3">
            <a asp-page="/Reservation" class="btn btn-primary font-weight-bold py-3 px-5">
                <i class="fa fa-calendar-check mr-2"></i>Book a Table Now
            </a>
        </div>
    </div>
</div>
<!-- Services End -->
