@page
@{
    ViewData["Title"] = "About - KOPPEE Coffee Shop";
    ViewData["ActivePage"] = "About";
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 position-relative overlay-bottom">
    <div class="d-flex flex-column align-items-center justify-content-center pt-0 pt-lg-5" style="min-height: 400px">
        <h1 class="display-4 mb-3 mt-0 mt-lg-5 text-white text-uppercase">Về Chúng Tôi</h1>
        <div class="d-inline-flex mb-lg-5">
            <p class="m-0 text-white"><a class="text-white" asp-page="/Index">Trang Chủ</a></p>
            <p class="m-0 text-white px-2">/</p>
            <p class="m-0 text-white">Giới Thiệu</p>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- About Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Về Chúng Tôi</h4>
            <h1 class="display-4">Phục Vụ Từ Năm 1950</h1>
        </div>
        <div class="row">
            <div class="col-lg-4 py-0 py-lg-5">
                <h1 class="mb-3">Câu Chuyện Của Chúng Tôi</h1>
                <h5 class="mb-3">Ra đời từ niềm đam mê sâu sắc với tách cà phê hoàn hảo.</h5>
                <p>KOPPEE bắt đầu từ năm 1950 như một quán cà phê gia đình nhỏ tại trung tâm Sài Gòn. Qua hơn bảy mươi năm, chúng tôi đã phát triển từ một quầy hàng ven đường khiêm tốn trở thành điểm đến yêu thích của những người yêu cà phê trên khắp Việt Nam.</p>
                <p>Mỗi hạt cà phê chúng tôi sử dụng đều được tuyển chọn kỹ lưỡng từ các trang trại cao nguyên uy tín và được rang tươi hàng ngày tại xưởng rang riêng của chúng tôi.</p>
            </div>
            <div class="col-lg-4 py-5 py-lg-0" style="min-height: 500px;">
                <div class="position-relative h-100">
                    <img class="position-absolute w-100 h-100" src="~/img/about.png" style="object-fit: cover;">
                </div>
            </div>
            <div class="col-lg-4 py-0 py-lg-5">
                <h1 class="mb-3">Tầm Nhìn</h1>
                <p>Chúng tôi tin rằng cà phê là một nghi thức—một khoảnh khắc bình yên, kết nối và niềm vui hàng ngày. Tầm nhìn của chúng tôi là mang lại trải nghiệm cà phê tốt nhất cho mỗi vị khách, ngay từ ngụm đầu tiên.</p>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>100% Hạt Cà Phê Hữu Cơ & Tươi</h5>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>Chuyên Gia Pha Chế Tại Chỗ</h5>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>Nguồn Cung Ứng Bền Vững</h5>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>Triết Lý Ưu Tiên Cộng Đồng</h5>
                <a asp-page="/Product/Index" class="btn btn-primary font-weight-bold py-2 px-4 mt-2">Xem Thực Đơn</a>
            </div>
        </div>
    </div>
</div>
<!-- About End -->

<!-- Stats Start -->
<div class="container-fluid my-5 py-5" style="background: #f8f3f2;">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-3 mb-4 mb-md-0">
                <h1 class="display-4 text-primary font-weight-bold">75+</h1>
                <h5>Năm Kinh Nghiệm</h5>
            </div>
            <div class="col-md-3 mb-4 mb-md-0">
                <h1 class="display-4 text-primary font-weight-bold">50+</h1>
                <h5>Món Trong Thực Đơn</h5>
            </div>
            <div class="col-md-3 mb-4 mb-md-0">
                <h1 class="display-4 text-primary font-weight-bold">10k+</h1>
                <h5>Khách Hàng Hài Lòng</h5>
            </div>
            <div class="col-md-3 mb-4 mb-md-0">
                <h1 class="display-4 text-primary font-weight-bold">15+</h1>
                <h5>Barista Chuyên Nghiệp</h5>
            </div>
        </div>
    </div>
</div>
<!-- Stats End -->
