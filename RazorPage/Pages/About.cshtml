@page
@{
    ViewData["Title"] = "About - KOPPEE Coffee Shop";
    ViewData["ActivePage"] = "About";
}

<!-- Page Header Start -->
<div class="container-fluid page-header mb-5 position-relative overlay-bottom">
    <div class="d-flex flex-column align-items-center justify-content-center pt-0 pt-lg-5" style="min-height: 400px">
        <h1 class="display-4 mb-3 mt-0 mt-lg-5 text-white text-uppercase">About Us</h1>
        <div class="d-inline-flex mb-lg-5">
            <p class="m-0 text-white"><a class="text-white" asp-page="/Index">Home</a></p>
            <p class="m-0 text-white px-2">/</p>
            <p class="m-0 text-white">About</p>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- About Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">About Us</h4>
            <h1 class="display-4">Serving Since 1950</h1>
        </div>
        <div class="row">
            <div class="col-lg-4 py-0 py-lg-5">
                <h1 class="mb-3">Our Story</h1>
                <h5 class="mb-3">Born from a deep passion for the perfect cup of coffee.</h5>
                <p>KOPPEE began in 1950 as a small family café in the heart of Saigon. Over seventy years, we have grown from a humble street-side stall to a beloved destination for coffee lovers across Vietnam.</p>
                <p>Every bean we use is hand-selected from trusted highland farms and roasted fresh daily in our in-house roastery.</p>
            </div>
            <div class="col-lg-4 py-5 py-lg-0" style="min-height: 500px;">
                <div class="position-relative h-100">
                    <img class="position-absolute w-100 h-100" src="~/img/about.png" style="object-fit: cover;">
                </div>
            </div>
            <div class="col-lg-4 py-0 py-lg-5">
                <h1 class="mb-3">Our Vision</h1>
                <p>We believe coffee is a ritual—a daily moment of calm, connection, and joy. Our vision is to bring the finest coffee experience to every guest, from the very first sip.</p>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>100% Organic &amp; Fresh Beans</h5>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>Expert Baristas On Site</h5>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>Sustainable Sourcing</h5>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>Community-First Philosophy</h5>
                <a asp-page="/Menu" class="btn btn-primary font-weight-bold py-2 px-4 mt-2">View Our Menu</a>
            </div>
        </div>
    </div>
</div>
<!-- About End -->

<!-- Stats Start -->
<div class="container-fluid my-5 py-5" style="background: #f8f3f2;">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-3 mb-4 mb-md-0">
                <h1 class="display-4 text-primary font-weight-bold">75+</h1>
                <h5>Years of Experience</h5>
            </div>
            <div class="col-md-3 mb-4 mb-md-0">
                <h1 class="display-4 text-primary font-weight-bold">50+</h1>
                <h5>Menu Items</h5>
            </div>
            <div class="col-md-3 mb-4 mb-md-0">
                <h1 class="display-4 text-primary font-weight-bold">10k+</h1>
                <h5>Happy Customers</h5>
            </div>
            <div class="col-md-3 mb-4 mb-md-0">
                <h1 class="display-4 text-primary font-weight-bold">15+</h1>
                <h5>Expert Baristas</h5>
            </div>
        </div>
    </div>
</div>
<!-- Stats End -->
