@page
@model IndexModel
@{
    ViewData["Title"] = "Home - KOPPEE Coffee Shop";
    ViewData["ActivePage"] = "Index";
}

<!-- Carousel Start -->
<div class="container-fluid p-0 mb-5">
    <div id="blog-carousel" class="carousel slide overlay-bottom" data-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img class="w-100" src="~/img/carousel-1.jpg" alt="KOPPEE Coffee">
                <div class="carousel-caption d-flex flex-column align-items-center justify-content-center">
                    <h2 class="text-primary font-weight-medium m-0">We Have Been Serving</h2>
                    <h1 class="display-1 text-white m-0">COFFEE</h1>
                    <h2 class="text-white m-0">* SINCE 1950 *</h2>
                </div>
            </div>
            <div class="carousel-item">
                <img class="w-100" src="~/img/carousel-2.jpg" alt="KOPPEE Coffee">
                <div class="carousel-caption d-flex flex-column align-items-center justify-content-center">
                    <h2 class="text-primary font-weight-medium m-0">We Have Been Serving</h2>
                    <h1 class="display-1 text-white m-0">COFFEE</h1>
                    <h2 class="text-white m-0">* SINCE 1950 *</h2>
                </div>
            </div>
        </div>
        <a class="carousel-control-prev" href="#blog-carousel" data-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </a>
        <a class="carousel-control-next" href="#blog-carousel" data-slide="next">
            <span class="carousel-control-next-icon"></span>
        </a>
    </div>
</div>
<!-- Carousel End -->

<!-- About Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">About Us</h4>
            <h1 class="display-4">Serving Since 1950</h1>
        </div>
        <div class="row">
            <div class="col-lg-4 py-0 py-lg-5">
                <h1 class="mb-3">Our Story</h1>
                <h5 class="mb-3">From a single cup of coffee to a beloved destination for coffee lovers across Vietnam.</h5>
                <p>KOPPEE was born from a passion for crafting the perfect cup of coffee. We source the finest beans from highlands of Vietnam and around the world, roasting them to perfection to bring you an unforgettable experience every time.</p>
                <a asp-page="/About" class="btn btn-secondary font-weight-bold py-2 px-4 mt-2">Learn More</a>
            </div>
            <div class="col-lg-4 py-5 py-lg-0" style="min-height: 500px;">
                <div class="position-relative h-100">
                    <img class="position-absolute w-100 h-100" src="~/img/about.png" style="object-fit: cover;">
                </div>
            </div>
            <div class="col-lg-4 py-0 py-lg-5">
                <h1 class="mb-3">Our Vision</h1>
                <p>We believe coffee is more than just a drink—it's a ritual, a moment of connection. Our vision is to create a welcoming space where everyone can enjoy premium coffee in a warm, inviting atmosphere.</p>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>100% Organic & Fresh Beans</h5>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>Expert Baristas On Site</h5>
                <h5 class="mb-3"><i class="fa fa-check text-primary mr-3"></i>Sustainable Sourcing</h5>
                <a asp-page="/Menu" class="btn btn-primary font-weight-bold py-2 px-4 mt-2">View Our Menu</a>
            </div>
        </div>
    </div>
</div>
<!-- About End -->

<!-- Service Start -->
<div class="container-fluid pt-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Our Services</h4>
            <h1 class="display-4">Fresh &amp; Organic Beans</h1>
        </div>
        <div class="row">
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="~/img/service-1.jpg" alt="Delivery">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-truck service-icon"></i>Fastest Door Delivery</h4>
                        <p class="m-0">Get your favourite coffee delivered hot and fresh to your doorstep within 30 minutes anywhere in the city.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="~/img/service-2.jpg" alt="Beans">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-coffee service-icon"></i>Fresh Coffee Beans</h4>
                        <p class="m-0">Sourced from the finest highland farms, our beans are roasted fresh daily to ensure maximum flavour and aroma.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="~/img/service-3.jpg" alt="Quality">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-award service-icon"></i>Best Quality Coffee</h4>
                        <p class="m-0">Award-winning recipes and barista expertise ensure every cup meets our uncompromising quality standards.</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-5">
                <div class="row align-items-center">
                    <div class="col-sm-5">
                        <img class="img-fluid mb-3 mb-sm-0" src="~/img/service-4.jpg" alt="Booking">
                    </div>
                    <div class="col-sm-7">
                        <h4><i class="fa fa-table service-icon"></i>Online Table Booking</h4>
                        <p class="m-0">Reserve your perfect table in seconds and enjoy a 30% discount on your first online reservation.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Service End -->

<!-- Offer Start -->
<div class="offer container-fluid my-5 py-5 text-center position-relative overlay-top overlay-bottom">
    <div class="container py-5">
        <h1 class="display-3 text-primary mt-3">50% OFF</h1>
        <h1 class="text-white mb-3">Weekend Special Offer</h1>
        <h4 class="text-white font-weight-normal mb-4 pb-3">Every Saturday & Sunday — Limited Time Only</h4>
        <form class="form-inline justify-content-center mb-4">
            <div class="input-group">
                <input type="text" class="form-control p-4" placeholder="Your Email" style="height: 60px;">
                <div class="input-group-append">
                    <button class="btn btn-primary font-weight-bold px-4" type="submit">Sign Up</button>
                </div>
            </div>
        </form>
    </div>
</div>
<!-- Offer End -->

<!-- Menu Preview Start (Dynamic from API) -->
<div class="container-fluid pt-5">
    <div class="container">
        <div class="section-title">
            <h4 class="text-primary text-uppercase" style="letter-spacing: 5px;">Menu &amp; Pricing</h4>
            <h1 class="display-4">Competitive Pricing</h1>
        </div>

        @if (Model.ApiError != null)
        {
            <div class="alert alert-warning">
                <i class="fa fa-exclamation-circle mr-2"></i>@Model.ApiError
            </div>
        }

        <div class="row" id="menu-preview">
            @if (Model.Products != null && Model.Products.Any())
            {
                var preview = Model.Products.Take(6).ToList();
                var hotGroup = preview.Take(3).ToList();
                var coldGroup = preview.Skip(3).Take(3).ToList();

                <div class="col-lg-6">
                    <h1 class="mb-5">Featured Items</h1>
                    @foreach (var p in hotGroup)
                    {
                        <div class="row align-items-center mb-5">
                            <div class="col-4 col-sm-3">
                                <img class="w-100 rounded-circle mb-3 mb-sm-0"
                                     src="@(string.IsNullOrEmpty(p.ImageUrl) ? "~/img/menu-1.jpg" : p.ImageUrl)"
                                     alt="@p.ProductName"
                                     onerror="this.src='/img/menu-1.jpg'">
                                <h5 class="menu-price">@p.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</h5>
                            </div>
                            <div class="col-8 col-sm-9">
                                <h4>@p.ProductName</h4>
                                <p class="m-0">@(string.IsNullOrEmpty(p.Description) ? "A perfect blend crafted with care for coffee lovers." : p.Description)</p>
                                @if (!p.IsAvailable)
                                {
                                    <span class="badge badge-secondary mt-1">Unavailable</span>
                                }
                            </div>
                        </div>
                    }
                </div>
                <div class="col-lg-6">
                    <h1 class="mb-5">Popular Picks</h1>
                    @foreach (var p in coldGroup)
                    {
                        <div class="row align-items-center mb-5">
                            <div class="col-4 col-sm-3">
                                <img class="w-100 rounded-circle mb-3 mb-sm-0"
                                     src="@(string.IsNullOrEmpty(p.ImageUrl) ? "~/img/menu-2.jpg" : p.ImageUrl)"
                                     alt="@p.ProductName"
                                     onerror="this.src='/img/menu-2.jpg'">
                                <h5 class="menu-price">@p.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</h5>
                            </div>
                            <div class="col-8 col-sm-9">
                                <h4>@p.ProductName</h4>
                                <p class="m-0">@(string.IsNullOrEmpty(p.Description) ? "A perfect blend crafted with care for coffee lovers." : p.Description)</p>
                                @if (!p.IsAvailable)
                                {
                                    <span class="badge badge-secondary mt-1">Unavailable</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else if (Model.ApiError == null)
            {
                <div class="col-12 text-center py-5">
                    <i class="fa fa-coffee fa-3x text-primary mb-3"></i>
                    <p>No products available at the moment.</p>
                </div>
            }
        </div>

        <div class="text-center mt-3 mb-5">
            <a asp-page="/Menu" class="btn btn-primary font-weight-bold py-3 px-5">View Full Menu</a>
        </div>
    </div>
</div>
<!-- Menu Preview End -->

<!-- Reservation Start -->
<div class="container-fluid reservation position-relative overlay-top overlay-bottom my-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 my-5 my-lg-0">
                <div class="p-5">
                    <div class="mb-4">
                        <h1 class="display-3 text-primary">30% OFF</h1>
                        <h1 class="text-white">For Online Reservation</h1>
                    </div>
                    <p class="text-white">Book your table online and receive an exclusive 30% discount on your entire order. Valid for dine-in reservations only.</p>
                    <ul class="list-inline text-white m-0">
                        <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>Instant confirmation</li>
                        <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>No reservation fee</li>
                        <li class="py-2"><i class="fa fa-check text-primary mr-3"></i>Free cancellation</li>
                    </ul>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="text-center p-5" style="background: rgba(51, 33, 29, .8);">
                    <h1 class="text-white mb-4 mt-5">Book Your Table</h1>
                    <p class="text-white mb-4">
                        <a asp-page="/Reservation" class="btn btn-primary font-weight-bold py-3 px-5">
                            <i class="fa fa-calendar-check mr-2"></i>Make a Reservation
                        </a>
                    </p>
                    <p class="text-white">Or call us: <strong class="text-primary">+84 028 123 4567</strong></p>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Reservation End -->

