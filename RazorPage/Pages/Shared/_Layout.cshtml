<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - KOPPEE Coffee Shop</title>

    <!-- Favicon -->
    <link href="~/favicon.ico" rel="icon" />

    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.gstatic.com" />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@200;400&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet" />

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet" />

    <!-- Libraries Stylesheet -->
    <link href="~/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet" />
    <link href="~/lib/tempusdominus/css/tempusdominus-bootstrap-4.min.css" rel="stylesheet" />

    <!-- KOPPEE Bootstrap Stylesheet -->
    <link href="~/css/style.min.css" rel="stylesheet" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Navbar Start -->
    <div class="container-fluid p-0 nav-bar">
        <nav class="navbar navbar-expand-lg bg-none navbar-dark py-3">
            <a asp-page="/Index" class="navbar-brand px-lg-4 m-0">
                <h1 class="m-0 display-4 text-uppercase text-white">KOPPEE</h1>
            </a>
            <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                <div class="navbar-nav ml-auto p-4">
                    <a asp-page="/Index" class="nav-item nav-link @(ViewData["ActivePage"]?.ToString() == "Index" ? "active" : "")">Trang Chủ</a>
                    <a asp-page="/About" class="nav-item nav-link @(ViewData["ActivePage"]?.ToString() == "About" ? "active" : "")">Giới Thiệu</a>
                    <a asp-page="/Service" class="nav-item nav-link @(ViewData["ActivePage"]?.ToString() == "Service" ? "active" : "")">Dịch Vụ</a>
                    <a asp-page="/Menu" class="nav-item nav-link @(ViewData["ActivePage"]?.ToString() == "Menu" ? "active" : "")">Thực Đơn</a>
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle @(ViewData["ActivePage"]?.ToString() is "Reservation" or "Testimonial" ? "active" : "")" data-toggle="dropdown">Trang</a>
                        <div class="dropdown-menu text-capitalize">
                            <a asp-page="/Reservation" class="dropdown-item @(ViewData["ActivePage"]?.ToString() == "Reservation" ? "active" : "")">Đặt Bàn</a>
                            <a asp-page="/Testimonial" class="dropdown-item @(ViewData["ActivePage"]?.ToString() == "Testimonial" ? "active" : "")">Đánh Giá</a>
                        </div>
                    </div>
                    <a asp-page="/Contact" class="nav-item nav-link @(ViewData["ActivePage"]?.ToString() == "Contact" ? "active" : "")">Liên Hệ</a>
                    @if (Context.Session.GetString("CustomerEmail") != null)
                    {
                        <div class="nav-item dropdown ml-3">
                            <a href="#" class="nav-link dropdown-toggle text-primary font-weight-bold" data-toggle="dropdown">
                                <i class="fa fa-user mr-1"></i>@Context.Session.GetString("CustomerFullName")
                            </a>
                            <div class="dropdown-menu">
                                <a asp-page="/Auth/Logout" class="dropdown-item text-danger">
                                    <i class="fa fa-sign-out-alt mr-2"></i>Đăng xuất
                                </a>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a asp-page="/Auth/Login" class="btn btn-primary font-weight-bold ml-3">
                            <i class="fa fa-sign-in-alt mr-1"></i>Đăng Nhập
                        </a>
                    }
                </div>
            </div>
        </nav>
    </div>
    <!-- Navbar End -->

    @RenderBody()

    <!-- Footer Start -->
    <div class="container-fluid footer text-white mt-5 pt-5 px-0 position-relative overlay-top">
        <div class="row mx-0 pt-5 px-sm-3 px-lg-5 mt-4">
            <div class="col-lg-3 col-md-6 mb-5">
                <h4 class="text-white text-uppercase mb-4" style="letter-spacing: 3px;">Liên Hệ</h4>
                <p><i class="fa fa-map-marker-alt mr-2"></i>123 Đường Cà Phê, Quận 1, TP. HCM</p>
                <p><i class="fa fa-phone-alt mr-2"></i>+84 028 123 4567</p>
                <p class="m-0"><i class="fa fa-envelope mr-2"></i>hello@koppee.vn</p>
            </div>
            <div class="col-lg-3 col-md-6 mb-5">
                <h4 class="text-white text-uppercase mb-4" style="letter-spacing: 3px;">Theo Dõi</h4>
                <p>Luôn kết nối để nhận những cảm hứng cà phê và ưu đãi đặc biệt mỗi ngày.</p>
                <div class="d-flex justify-content-start">
                    <a class="btn btn-lg btn-outline-light btn-lg-square mr-2" href="#"><i class="fab fa-twitter"></i></a>
                    <a class="btn btn-lg btn-outline-light btn-lg-square mr-2" href="#"><i class="fab fa-facebook-f"></i></a>
                    <a class="btn btn-lg btn-outline-light btn-lg-square mr-2" href="#"><i class="fab fa-linkedin-in"></i></a>
                    <a class="btn btn-lg btn-outline-light btn-lg-square" href="#"><i class="fab fa-instagram"></i></a>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-5">
                <h4 class="text-white text-uppercase mb-4" style="letter-spacing: 3px;">Giờ Mở Cửa</h4>
                <div>
                    <h6 class="text-white text-uppercase">Thứ Hai - Thứ Sáu</h6>
                    <p>7:00 AM - 10:00 PM</p>
                    <h6 class="text-white text-uppercase">Thứ Bảy - Chủ Nhật</h6>
                    <p>8:00 AM - 11:00 PM</p>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 mb-5">
                <h4 class="text-white text-uppercase mb-4" style="letter-spacing: 3px;">Bản Tin</h4>
                <p>Đăng ký để nhận tin tức mới nhất và các ưu đãi đặc biệt.</p>
                <div class="w-100">
                    <div class="input-group">
                        <input type="text" class="form-control border-light" style="padding: 25px;" placeholder="Email của bạn">
                        <div class="input-group-append">
                            <button class="btn btn-primary font-weight-bold px-3">Đăng Ký</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-fluid text-center text-white border-top mt-4 py-4 px-sm-3 px-md-5" style="border-color: rgba(256, 256, 256, .1) !important;">
            <p class="mb-0 text-white">&copy; 2026 <strong>Cửa hàng Cà phê KOPPEE</strong>. Bảo lưu mọi quyền.</p>
        </div>
    </div>
    <!-- Footer End -->

    <!-- Back to Top -->
    <a href="#" class="btn btn-lg btn-primary btn-lg-square back-to-top"><i class="fa fa-angle-double-up"></i></a>

    <!-- JavaScript Libraries -->
    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/easing/easing.min.js"></script>
    <script src="~/lib/waypoints/waypoints.min.js"></script>
    <script src="~/lib/owlcarousel/owl.carousel.min.js"></script>
    <script src="~/lib/tempusdominus/js/moment.min.js"></script>
    <script src="~/lib/tempusdominus/js/moment-timezone.min.js"></script>
    <script src="~/lib/tempusdominus/js/tempusdominus-bootstrap-4.min.js"></script>
    <script src="~/js/main.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>